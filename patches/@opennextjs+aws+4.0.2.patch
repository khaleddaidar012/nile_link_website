+// cross-platform recursive directory copy (works with Unicode paths on Windows)
+function copyDirSync(src, dest, opts = {}) {
+    fs.mkdirSync(dest, { recursive: true });
+    const entries = fs.readdirSync(src, { withFileTypes: true });
+    for (const entry of entries) {
+        const srcPath = path.join(src, entry.name);
+        const destPath = path.join(dest, entry.name);
+        if (entry.isDirectory()) {
+            copyDirSync(srcPath, destPath, opts);
+        } else if (entry.isFile() || entry.isSymbolicLink()) {
+            try {
+                fs.copyFileSync(srcPath, destPath, fs.constants.COPYFILE_FICLONE);
+            } catch {
+                if (opts.dereference && entry.isSymbolicLink()) {
+                    const target = fs.readlinkSync(srcPath);
+                    fs.copyFileSync(target, destPath);
+                } else {
+                    fs.copyFileSync(srcPath, destPath);
+                }
+            }
+        }
+    }
